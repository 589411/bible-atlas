      },
      "script": [
        { "who": "旁白", "text": "兒子淪落到與豬搶食,終於醒悟,起來往父親那裡去——" },
        { "who": "jesus", "text": "相離還遠,他父親看見,就動了慈心,跑去抱著他的頸項,連連與他親嘴。" },
        { "who": "jesus", "text": "因為我這個兒子是死而復活,失而又得的。", "key": true }
      ]
    },
    "太8": {
      "era": "gospels", "type": "對話", "city": null,
      "title": "平靜風浪",
      "quote": "你們這小信的人哪,為甚麼膽怯呢?",
      "ref": "馬太福音 8:25-27;馬可福音 4:38-41;路加福音 8:24-25",
      "parallels": ["可4", "路8"],
      "hook": "船在加利利海上遇到狂風,浪幾乎把船打翻,門徒嚇得喪膽——而耶穌竟在船尾睡著。他們搖醒他。一個人,能對風浪說話嗎?",
      "cast": {
        "jesus": { "name": "耶穌", "faction": "messiah", "avatar": { "skin": "#d8a878", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#f0e8d8" } },
        "disciples": { "name": "門徒", "faction": "folk", "avatar": { "skin": "#c89868", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#7a4a3a" } }
      },
      "script": [
