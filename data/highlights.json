      "hook": "兵丁把耶穌釘上十字架,在他衣服上拈鬮。眼前是嘲笑、是釘痕、是不公的死刑。受刑的人通常咒罵。耶穌開口的第一句,卻是為加害者向天父求情。",
      "cast": {
        "jesus": { "name": "耶穌", "faction": "messiah", "avatar": { "skin": "#d8a878", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#f0e8d8" } }
      },
      "script": [
        { "who": "旁白", "text": "到了髑髏地,他們把耶穌釘在十字架上,左右各釘一個犯人。兵丁拈鬮分他的衣服。" },
        { "who": "jesus", "text": "父阿!赦免他們;因為他們所做的,他們不曉得。", "key": true }
      ]
    },
    "太28": {
      "era": "gospels", "type": "對話", "city": null,
      "title": "空墳與大使命",
      "quote": "我就常與你們同在,直到世界的末了。",
