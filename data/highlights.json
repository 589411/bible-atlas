    "路10": {
      "era": "gospels", "type": "教導", "city": null,
      "title": "好撒馬利亞人",
      "quote": "你去照樣行罷。",
      "ref": "路加福音 10:29-37",
      "hook": "一個律法師想為難耶穌:誰是我的鄰舍?耶穌沒給定義,反而講了個故事——被打個半死的人,身邊走過祭司、利未人,最後停下的卻是最不被待見的那種人。",
      "cast": {
        "jesus": { "name": "耶穌", "faction": "messiah", "avatar": { "skin": "#d8a878", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#f0e8d8" } },
        "lawyer": { "name": "律法師", "faction": "folk", "avatar": { "skin": "#d8a878", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#6a6a8a" } }
      },
      "script": [
        { "who": "旁白", "text": "祭司和利未人都從那受傷的人旁邊繞了過去,惟有一個被人看不起的撒瑪利亞人停下來,包紮、照顧他。耶穌問:這三人哪一個是鄰舍?" },
        { "who": "lawyer", "text": "是憐憫他的。" },
        { "who": "jesus", "text": "你去照樣行罷。", "key": true }
      ]
    },
    "約11": {
      "era": "gospels", "type": "對話", "city": null,
      "title": "復活在我",
      "quote": "復活在我,生命也在我。信我的人雖然死了,也必復活。",
      "ref": "約翰福音 11:21-26",
      "hook": "拉撒路死了四天,墳墓都封住了,耶穌才趕到。馬大迎上來,話裡有信、也有遺憾。面對親人的死,耶穌把自己擺在一個驚人的位置上。",
      "cast": {
        "jesus": { "name": "耶穌", "faction": "messiah", "avatar": { "skin": "#d8a878", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#f0e8d8" } },
        "martha": { "name": "馬大", "faction": "folk", "avatar": { "skin": "#e0b890", "hair": "#3a2a1a", "robe": "#9a6a7a" } }
      },
      "script": [
        { "who": "martha", "text": "主阿,你若早在這裡,我兄弟必不死。" },
        { "who": "jesus", "text": "復活在我,生命也在我。信我的人雖然死了,也必復活。", "key": true },
        { "who": "jesus", "text": "你信這話麼?" }
      ]
    },
    "路23": {
      "era": "gospels", "type": "禱告", "city": "jerusalem",
      "title": "十架上的赦免",
      "quote": "父阿!赦免他們;因為他們所做的,他們不曉得。",
