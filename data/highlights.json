      "hook": "走到該撒利亞腓立比,耶穌問門徒:別人說我是誰?眾說紛紜。然後他把問題轉向他們自己——你們說我是誰?彼得的回答,將定下教會的根基。",
      "cast": {
        "jesus": { "name": "耶穌", "faction": "messiah", "avatar": { "skin": "#d8a878", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#f0e8d8" } },
        "peter": { "name": "西門彼得", "faction": "folk", "avatar": { "skin": "#c89868", "hair": "#3a2a1a", "beard": "#3a2a1a", "robe": "#7a4a3a" } }
